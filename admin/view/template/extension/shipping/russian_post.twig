{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
	    <button onclick="$('#content #apply').attr('value', '1'); $('#' + $('#content form').attr('id')).submit();" data-toggle="tooltip" title="{{ button_apply }}" class="btn btn-success"><i class="fa fa-save"></i></button>
        <button type="submit" form="form-ups" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{%  if error_success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ error_success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-shipping" class="form-horizontal">
		  <input type="hidden" name="apply" id="apply" value="0">
		  <ul class="nav nav-tabs">
			<li class="active"><a href="#tab-shipping" data-toggle="tab">{{ tab_shipping }}</a></li>
			<li><a href="#tab-setting" data-toggle="tab">{{ tab_setting }}</a></li>
		  </ul>
		  <div class="tab-content">
			<div class="tab-pane active" id="tab-shipping">
			  <div class="row">
				<div class="col-sm-4">
				  <ul class="nav nav-pills nav-stacked" id="russian-post">
					{% set module_row = 0 %}
					{% if shipping_russian_post %}
					{% for module in shipping_russian_post %}
					<li class="row-{{ module_row }}{% if module_row == 0 %} active {% endif %}"><a class="item" href="#tab-{{ module_row }}" data-toggle="tab">{{ lang[module.type] }} <i class="pull-right fa fa-trash-o" onclick="showAlert(); $('.row-{{ module_row }}').remove(); $('#russian-post a:first').tab('show');"></i></a></li>
					{% set module_row = module_row + 1 %}
					{% endfor %}
					{% endif %}
					<li id="add-module">
					  <div class="input-group">
                        <select name="select_shipping" class="form-control">
						  {% for i in 0..32 %}
						  <option value="{{ i }}">{{ lang[i] }}</option>
						  {% endfor %}
						</select>
                        <span class="input-group-btn">
                          <span onclick="addModule();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></span>
	                    </span>
                      </div>
					</li>
				  </ul>
				</div>
				<div class="col-sm-8">
				  <div class="tab-content">
					{% set module_row = 0 %}
					{% if shipping_russian_post %}
					{% for module in shipping_russian_post %}
					<div class="row-{{ module_row }} tab-pane{% if module_row == 0 %} active {% endif %}" id="tab-{{ module_row }}">
					  <input value="{{ module.type }}" type="hidden" name="shipping_russian_post[{{ module_row }}][type]" />
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="free-{{ module_row }}">{{ entry_free }}</label>
						<div class="col-sm-8">
						  <input type="text" name="shipping_russian_post[{{ module_row }}][free]" value="{{ module.free }}" id="free-{{ module_row }}" class="form-control" />
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="limit-{{ module_row }}"><span data-toggle="tooltip" title="{{ help_limit }}">{{ entry_limit }}</span></label>
						<div class="col-sm-8">
						  <input type="text" name="shipping_russian_post[{{ module_row }}][limit]" value="{{ module.limit }}" id="limit-{{ module_row }}" class="form-control" />
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="cost-{{ module_row }}">{{ entry_cost }}</label>
						<div class="col-sm-8">
						  <div class="row">
							<div class="col-sm-6">
							  <select name="shipping_russian_post[{{ module_row }}][cost_prefix]" class="form-control">
								{% if module.cost_prefix == '+' %}
								<option selected="selected" value="+">+</option>
								<option value="%">%</option>
								{% else %}
								<option value="+">+</option>
								<option selected="selected" value="%">%</option>
								{% endif %}
							  </select>
							</div>
							<div class="col-sm-6">
							  <input type="text" name="shipping_russian_post[{{ module_row }}][cost]" value="{{ module.cost }}" id="cost-{{ module_row }}" class="form-control" />
							</div>
						  </div>
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="date-{{ module_row }}">{{ entry_date }}</label>
						<div class="col-sm-8">
						  <input type="text" name="shipping_russian_post[{{ module_row }}][date]" value="{{ module.date }}" id="date-{{ module_row }}" class="form-control" />
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="thumb-image{{ module_row }}">{{ entry_image }}</label>
						<div class="col-sm-8">
						  <a href="" id="thumb-image{{ module_row }}" data-toggle="image"><img style="width: {{ shipping_russian_post_image_width }}px; height: {{ shipping_russian_post_image_height }}px;" src="{{ images[module_row]['thumb'] }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="shipping_russian_post_images[{{ module_row }}]" value="{{ images[module_row]['image'] }}" id="input-image{{ module_row }}" />
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="tax-class-{{ module_row }}">{{ entry_tax_class }}</label>
						<div class="col-sm-8">
						  <select name="shipping_russian_post[{{ module_row }}][tax_class_id]" id="tax-class-{{ module_row }}" class="form-control">
							<option value="0">{{ text_none }}</option>
							{% for tax_class in tax_classes %}
							{%  if tax_class.tax_class_id == module.tax_class_id %}
							<option value="{{ tax_class.tax_class_id }}" selected="selected">{{ tax_class.title }}</option>
							{% else %}
							<option value="{{ tax_class.tax_class_id }}">{{ tax_class.title }}</option>
							{% endif %}
							{% endfor %}
						  </select>
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="geo-zone-{{ module_row }}">{{ entry_geo_zone }}</label>
						<div class="col-sm-8">
						  <select name="shipping_russian_post[{{ module_row }}][geo_zone_id]" id="geo-zone-{{ module_row }}" class="form-control">
							<option value="0">{{ text_all_zones }}</option>
							{% for geo_zone in geo_zones %}
							{% if geo_zone.geo_zone_id == module.geo_zone_id %}
							<option value="{{ geo_zone.geo_zone_id }}" selected="selected">{{ geo_zone.name }}</option>
							{% else %}
							<option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>
							{% endif %}
							{% endfor %}
						  </select>
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="status-{{ module_row }}">{{ entry_status }}</label>
						<div class="col-sm-8">
						  <select name="shipping_russian_post[{{ module_row }}][status]" id="status-{{ module_row }}" class="form-control">
							{% if module.status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</div>
					  </div>
					  <div class="form-group">
						<label class="col-sm-4 control-label" for="sort-order-{{ module_row }}">{{ entry_sort_order }}</label>
						<div class="col-sm-8">
						  <input type="text" name="shipping_russian_post[{{ module_row }}][sort_order]" value="{{ module.sort_order }}" id="sort-order-{{ module_row }}" class="form-control" />
						</div>
					  </div>
					</div>
					{% set module_row = module_row + 1 %}
					{% endfor %}
					{% else %}
					<div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_no_shipping }} 
					<button type="button" class="close" data-dismiss="alert">&times;</button></div>
					{% endif %}
					<div id="new-tab"></div>
				  </div>
				</div>
			  </div>
			</div>
			<div class="tab-pane" id="tab-setting">
			  <fieldset>
                <legend>{{ text_general }}</legend>
				<div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-ststus">{{ entry_status }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_status" id="russian-post-ststus" class="form-control">
					  {% if shipping_russian_post_status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
				<div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-type-query">{{ entry_type_query }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_type_query" id="russian-post-type-query" class="form-control">
					  {% if shipping_russian_post_type_query %}
					  <option value="1" selected="selected">{{ text_api }}</option>
					  <option value="0">{{ text_light }}</option>
					  {% else %}
					  <option value="1">{{ text_api }}</option>
					  <option value="0" selected="selected">{{ text_light }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_sort_order" value="{{ shipping_russian_post_sort_order }}" placeholder="{{ entry_sort_order }}" id="russian-post-sort-order" class="form-control" />
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="input-show-image">{{ entry_show_images }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_show_images" id="input-show-image" class="form-control">
					  {% if shipping_russian_post_show_images %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="input-image-width"><span data-toggle="tooltip" title="{{ help_image_size }}">{{ entry_image_size }}</span></label>
				  <div class="col-sm-10">
				    <div class="row">
					  <div class="col-sm-6">
					    <input type="text" name="shipping_russian_post_image_width" value="{{ shipping_russian_post_image_width }}" placeholder="{{ entry_width }}" id="input-image-width" class="form-control" />
					  </div>
					  <div class="col-sm-6">
					    <input type="text" name="shipping_russian_post_image_height" value="{{ shipping_russian_post_image_height }}" placeholder="{{ entry_height }}" class="form-control" />
					  </div>
				    </div>
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-debug">{{ entry_debug }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_debug" id="russian-post-debug" class="form-control">
					  {% if shipping_russian_post_debug %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			  </fieldset>
			  <fieldset>
                <legend>{{ text_product }}</legend>
				<div class="form-group">
				  <label class="col-sm-2 control-label" for="input-weight-class"><span data-toggle="tooltip" title="{{ help_weight_class }}">{{ entry_weight_class }}</span></label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_weight_class_id" id="input-weight-class" class="form-control">
					  {% for weight_class in weight_classes %}
					  {% if weight_class.weight_class_id == shipping_russian_post_weight_class_id %}
					  <option value="{{ weight_class.weight_class_id }}" selected="selected">{{ weight_class.title }}</option>
					  {% else %}
					  <option value="{{ weight_class.weight_class_id }}">{{ weight_class.title }}</option>
					  {% endif %}
					  {% endfor %}
				    </select>
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-weight">{{ entry_weight }}</label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_weight" value="{{ shipping_russian_post_weight }}" placeholder="{{ entry_weight }}" id="russian-post-weight" class="form-control" />
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-weight-pack">{{ entry_weight_pack }}</label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_weight_pack" value="{{ shipping_russian_post_weight_pack }}" placeholder="{{ entry_weight_pack }}" id="russian-post-weight-pack" class="form-control" />
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-declare">{{ entry_declare }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_declare" id="russian-post-declare" class="form-control">
					  {% if shipping_russian_post_declare %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			  </fieldset>
			  <fieldset>
                <legend>{{ text_shipping }}</legend>
				<div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-postcode-default"><span data-toggle="tooltip" title="{{ help_postcode_default }}">{{ entry_postcode_default }}</span></label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_postcode_default" value="{{ shipping_russian_post_postcode_default }}" placeholder="{{ entry_postcode_default }}" id="russian-post-postcode-default" class="form-control" />
				  </div>
			    </div>
			    <div class="form-group required">
				  <label class="col-sm-2 control-label" for="russian-post-city">{{ entry_city }}</label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_city" value="{{ shipping_russian_post_city }}" placeholder="{{ entry_city }}" id="russian-post-city" class="form-control" />
				    {% if error_city %}
				    <div class="text-danger">{{ error_city }}</div>
				    {% endif %}
				  </div>
			    </div>
			    <div class="form-group required">
				  <label class="col-sm-2 control-label" for="russian-post-postcode">{{ entry_postcode }}</label>
				  <div class="col-sm-10">
				    <input type="text" name="shipping_russian_post_postcode" value="{{ shipping_russian_post_postcode }}" placeholder="{{ entry_postcode }}" id="russian-post-postcode" class="form-control" />
				    {% if error_postcode %}
				    <div class="text-danger">{{ error_postcode }}</div>
				    {% endif %}
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-date">{{ entry_time }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_date" id="russian-post-date" class="form-control">
					  {% if shipping_russian_post_date %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			    <div class="form-group">
				  <label class="col-sm-2 control-label" for="russian-post-hide">{{ entry_hide }}</label>
				  <div class="col-sm-10">
				    <select name="shipping_russian_post_hide" id="russian-post-hide" class="form-control">
					  {% if shipping_russian_post_hide %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
				    </select>
				  </div>
			    </div>
			  </fieldset>
			</div>
		  </div>
		</form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
function showAlert() {
	if ($('#russian-post li').length == 2) {
		$('#new-tab').before('<div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_no_shipping }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>');	
	}
}

var module_row = {{ module_row }};

function addModule() {
	$('.alert-info').remove();
	
	var type_val = $('select[name=\'select_shipping\']').val();
	var type_text = $('select[name=\'select_shipping\'] option:selected').text();
	
	html   = '<div class="row-' + module_row + ' tab-pane" id="tab-' + module_row + '">';
	html  += '<input value="' + type_val + '" type="hidden" name="shipping_russian_post[' + module_row + '][type]" />';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="free-' + module_row + '">{{ entry_free }}</label><div class="col-sm-8"><input type="text" name="shipping_russian_post[' + module_row + '][free]" value="" id="free-' + module_row + '" class="form-control" /></div></div>';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="limit-' + module_row + '">{{ entry_limit }}</label><div class="col-sm-8"><input type="text" name="shipping_russian_post[' + module_row + '][limit]" value="" id="limit-' + module_row + '" class="form-control" /></div></div>';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="cost-' + module_row + '">{{ entry_cost }}</label><div class="col-sm-8"><div class="row"><div class="col-sm-6"><select name="shipping_russian_post[' + module_row + '][cost_prefix]" class="form-control"><option value="+">+</option><option value="%">%</option></select></div><div class="col-sm-6"><input type="text" name="shipping_russian_post[' + module_row + '][cost]" value="" id="cost-' + module_row + '" class="form-control" /></div></div></div></div>';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="date-' + module_row + '">{{ entry_date }}</label><div class="col-sm-8"><input type="text" name="shipping_russian_post[' + module_row + '][date]" value="" id="date-' + module_row + '" class="form-control" /></div></div>';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="thumb-image' + module_row + '">{{ entry_image }}</label><div class="col-sm-8"><a href="" id="thumb-image' + module_row + '" data-toggle="image"><img style="width: {{ shipping_russian_post_image_width }}px; height: {{ shipping_russian_post_image_height }}px;" src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="shipping_russian_post_images[' + module_row + ']" value="" id="input-image' + module_row + '" /></div></div>';
	html  += '<div class="form-group"><label class="col-sm-4 control-label" for="tax-class-' + module_row + '">{{ entry_tax_class }}</label><div class="col-sm-8"><select name="shipping_russian_post[' + module_row + '][tax_class_id]" id="tax-class-' + module_row + '" class="form-control"><option value="0">{{ text_none }}</option>';
	{% for tax_class in tax_classes %}
	html += '<option value="{{ tax_class.tax_class_id }}">{{ tax_class.title }}</option>';
    {% endfor %}
	html += '</select></div></div>';
	html += '<div class="form-group"><label class="col-sm-4 control-label" for="geo-zone-' + module_row + '">{{ entry_geo_zone }}</label><div class="col-sm-8"><select name="shipping_russian_post[' + module_row + '][geo_zone_id]" id="geo-zone-' + module_row + '" class="form-control"><option value="0">{{ text_all_zones }}</option>';
	{% for geo_zone in geo_zones %}
	html += '<option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>';
    {% endfor %}
	html += '</select></div></div>';
	html += '<div class="form-group"><label class="col-sm-4 control-label" for="status-' + module_row + '">{{ entry_status }}</label><div class="col-sm-8"><select name="shipping_russian_post[' + module_row + '][status]" id="status-' + module_row + '" class="form-control"><option selected="selected" value="1">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></select></div></div>';
	html += '<div class="form-group"><label class="col-sm-4 control-label" for="sort-order-' + module_row + '">{{ entry_sort_order }}</label><div class="col-sm-8"><input type="text" name="shipping_russian_post[' + module_row + '][sort_order]" value="" id="sort-order-' + module_row + '" class="form-control" /></div></div></div>';				

	$('#new-tab').before(html);
	
	html2 = '<li class="row-' + module_row + '"><a href="#tab-' + module_row + '" data-toggle="tab">' + type_text + ' <i class="pull-right fa fa-trash-o" onclick="showAlert(); $(\'.row-' + module_row + '\').remove(); $(\'#russian-post a:first\').tab(\'show\')"></i></a></li>';
	
	$('#add-module').before(html2);
	
	$('#russian-post a:last').tab('show');

