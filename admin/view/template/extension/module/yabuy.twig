{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{cancel}}" data-toggle="tooltip" title="{{button_cancel}}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{heading_title}}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{text_edit}}</h3>
      </div>
      <div class="panel-body">
  
    <form action="{{action}}" method="post" enctype="multipart/form-data" id="form" class="form-horizontal">
	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-status">{{entry_status}}</label>
		<div class="col-sm-9">
		  <select name="module_yabuy_status" id="input-status" class="form-control">
			{%if module_yabuy_status %}
			<option value="1" selected="selected">{{text_enabled}}</option>
			<option value="0">{{text_disabled}}</option>
			{% else %}
			<option value="1">{{text_enabled}}</option>
			<option value="0" selected="selected">{{text_disabled}}</option>
			{% endif %}
		  </select>
		</div>
	  </div>
	  
	  <input type="hidden" name="yabuy_dbs" value="0" />

	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-yacompany">№ кампании в Маркете:</label>
		<div class="col-sm-9">
		  <input type="text" name="yabuy_yacompany" value="{{yabuy_yacompany}}" id="input-yacompany" class="form-control" />
		</div>
	  </div>
	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-token">{{entry_token}}</label>
		<div class="col-sm-9">
		  <input type="text" name="yabuy_token" value="{{yabuy_token}}" id="input-token" class="form-control" />
		</div>
	  </div>
	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-yalogin">{{entry_yalogin}}</label>
		<div class="col-sm-9">
		  <input type="text" name="yabuy_login" value="{{yabuy_login}}" id="input-yalogin" class="form-control" style="width: 260px;" />@yandex.ru
		</div>
	  </div>
	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-oauth_token">{{entry_oauth_token}}</label>
		<div class="col-sm-9">
		  <label class="control-label">
            {%if is_token_exists %}
			Получен. 
			<a href="javascript:void(0);" id="get_token">Обновить</a>
			{% else %}
			<span style="color: red;" data-toggle="tooltip" title="Требуется зарегистрировать приложение Яндекс">НЕ получен. </span>
		    <a href="javascript:void(0);" id="get_token">{{text_get}}</a>
			{% endif %}
		  </label>
		</div>
	  </div>
	  
	  <div class="form-group">
		<div class="col-sm-3"></div>
		<div class="col-sm-9">
			<input type="checkbox" name="yabuy_long_id" value="1" id="cb_long_id"{%if yabuy_long_id %} checked{% endif %} />
			<label class="control-label" for="cb_long_id">В OpenCart ID товара длиннее 6 цифр, и нет опций</span></label>
		</div>
	  </div>
	  
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_unpaid_status">Статус неоплаченного заказа:</label>
		<div class="col-sm-7">
		  <select name="yabuy_unpaid_status" class="form-control">			
		    <option value="0"{%if yabuy_unpaid_status == 0 %} selected="selected"{% endif %}>Ошибочные заказы</option>
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_unpaid_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_processing_status">Статус заказа в обработке:</label>
		<div class="col-sm-7">
		  <select name="yabuy_processing_status" class="form-control">			
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_processing_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_delivery_status">Статус заказа, переданного на доставку:</label>
		<div class="col-sm-7">
		  <select name="yabuy_delivery_status" class="form-control">			
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_delivery_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_pickup_status">Статус заказа, доставленного в ПВЗ:</label>
		<div class="col-sm-7">
		  <select name="yabuy_pickup_status" class="form-control">			
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_pickup_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_delivered_status">Статус заказа, врученного покупателю:</label>
		<div class="col-sm-7">
		  <select name="yabuy_delivered_status" class="form-control">			
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_delivered_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>
	  <div class="form-group _change_status">
		<label class="col-sm-3 control-label" for="yabuy_cancelled_status">Статус отмененного заказа:</label>
		<div class="col-sm-7">
		  <select name="yabuy_cancelled_status" class="form-control">			
			{%for order_status in order_statuses %}
			<option value="{{order_status.order_status_id}}"{%if order_status.order_status_id == yabuy_cancelled_status %} selected="selected"{% endif %}>{{order_status.name}}</option>
			{% endfor %}
		  </select>
		</div>
	  </div>

	  <div class="form-group">
		<label class="col-sm-3 control-label" for="input-weekends"><span data-toggle="tooltip" title="Сроки доставки сдвигаются с учетом выходных" >Выходные дни:</span></label>
		<div class="col-sm-9">
			<input type="checkbox" name="yabuy_weekend_sat" value="1" id="cb_weekend_sat"{%if yabuy_weekend_sat %} checked{% endif %} /><label for="cb_weekend_sat">Сб.</label>
			<input type="checkbox" name="yabuy_weekend_sun" value="1" id="cb_weekend_sun"{%if yabuy_weekend_sun %} checked{% endif %} /><label for="cb_weekend_sun">Вс.</label>
		</div>
	  </div>
	  
    </form>
                </div>
            </div>
        </div>
    </div>
<script type="text/javascript"><!--
$('#get_token').click(function() {
	var url = 'https://oauth.yandex.ru/authorize?response_type=code&client_id={{yandex_oauth_id}}&display=popup';
	window.open(url, 'ya_oauth','width=600,height=350,resizable=yes,scrollbars=yes,status=yes,location=false');
	return false;
});
//--></script>
{{ footer }}
