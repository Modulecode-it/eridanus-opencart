{{ header }}{{ column_left }} 
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a></div>
      <h1><i class="fa fa-search"></i> {{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %} 
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %} 
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if (error_warning) %} 
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }} 
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %} 
    <div class="panel panel-default">
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form" class="form-horizontal">
          <ul class="nav nav-tabs" id="tabs_general">
            <li class="active"><a href="#tab-general" data-toggle="tab"><i class="fa fa-power-off"></i> {{ tab_general }}</a></li>
            <li><a href="#tab-log" data-toggle="tab"><i class="fa fa-eye"></i> {{ tab_log }}</a></li>
          </ul>
          <div class="tab-content">
            <div class="tab-pane active" id="tab-general">

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-success{{ shoputils_antispam_contact_status ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_status" value="1"{{ shoputils_antispam_contact_status ? ' checked="checked"' : '' }} /> {{ text_enabled }}</label>
                        <label class="btn btn-danger{{ not shoputils_antispam_contact_status ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_status" value="0"{{ not shoputils_antispam_contact_status ? ' checked="checked"' : '' }} /> {{ text_disabled }}</label>
                    </div>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-registr_status">{{ entry_registr_status }}</label>
                <div class="col-sm-10">
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-success{{ shoputils_antispam_contact_registr_status ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_registr_status" value="1"{{ shoputils_antispam_contact_registr_status ? ' checked="checked"' : '' }} /> {{ text_enabled }}</label>
                        <label class="btn btn-danger{{ not shoputils_antispam_contact_registr_status ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_registr_status" value="0"{{ not shoputils_antispam_contact_registr_status ? ' checked="checked"' : '' }} /> {{ text_disabled }}</label>
                    </div>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <textarea name="shoputils_antispam_contact_word" id="input-word" placeholder="{{ entry_word }}" class="form-control">{{ shoputils_antispam_contact_word }}</textarea>
                  <span class="help-block">{{ help_word }}</span>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <textarea name="shoputils_antispam_contact_ip" id="input-ip" placeholder="{{ entry_ip }}" class="form-control">{{ shoputils_antispam_contact_ip }}</textarea>
                  <span class="help-block">{{ help_ip }}</span>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-not_found">{{ entry_not_found }}</label>
                <div class="col-sm-10">
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-success{{ shoputils_antispam_contact_not_found ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_not_found" value="1"{{ shoputils_antispam_contact_not_found ? ' checked="checked"' : '' }} /> {{ text_enabled }}</label>
                        <label class="btn btn-danger{{ not shoputils_antispam_contact_not_found ? ' active' : '' }}"><input type="radio" name="shoputils_antispam_contact_not_found" value="0"{{ not shoputils_antispam_contact_not_found ? ' checked="checked"' : '' }} /> {{ text_disabled }}</label>
                    </div>
                  <span class="help-block">{{ help_not_found }}</span>
                </div>
              </div>

            </div><!-- </div id="tab-general"> -->
            <div class="tab-pane" id="tab-log">

              <fieldset>
                <legend>{{ text_contact }}</legend>

                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-log">{{ entry_log }}</label>
                  <div class="col-sm-8">
                    <input type="hidden" name="shoputils_antispam_contact_log_filename" value="{{ log_filename }}" />
                    <select name="shoputils_antispam_contact_log" id="input-log" class="form-control">
                      {% for key,value in logs %} 
                      {% if (key == shoputils_antispam_contact_log) %} 
                      <option value="{{ key }}"
                          selected="selected">{{ value }}</option>
                      {% else %} 
                      <option value="{{ key }}">{{ value }}</option>
                      {% endif %} 
                      {% endfor %} 
                    </select>
                    <span class="help-block">{{ help_log }}</span>
                  </div>
                  <div class="col-sm-2">
                    <a class="btn btn-success" id="button-download" href="{{ download }}"><i class="fa fa-download"></i> {{ button_download }}</a>
                    <a class="btn btn-danger" id="button-clear" data-loading-text="{{ text_loading }}"><i class="fa fa-eraser"></i> {{ button_clear }}</a>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-2 control-label">{{ entry_log_file }}</label>
                  <div class="col-sm-10">
                    <div class="well well-sm" style="height: 300px; overflow: auto;">
                      <pre id="pre-log" style="font-size:11px; min-height: 280px;">{% for log_line in log_lines %} {{ log_line }}{% endfor %}</pre>
                    </div>
                    <span class="help-block">{{ help_log_file }}</span>
                  </div>
                </div>

                <legend>{{ text_registr }}</legend>

                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-registr_log">{{ entry_log }}</label>
                  <div class="col-sm-8">
                    <input type="hidden" name="shoputils_antispam_contact_registr_log_filename" value="{{ log_registr_filename }}" />
                    <select name="shoputils_antispam_contact_registr_log" id="input-registr_log" class="form-control">
                      {% for key,value in logs %} 
                      {% if (key == shoputils_antispam_contact_registr_log) %} 
                      <option value="{{ key }}"
                          selected="selected">{{ value }}</option>
                      {% else %} 
                      <option value="{{ key }}">{{ value }}</option>
                      {% endif %} 
                      {% endfor %} 
                    </select>
                    <span class="help-block">{{ help_registr_log }}</span>
                  </div>
                  <div class="col-sm-2">
                    <a class="btn btn-success" id="button-registr_download" href="{{ registr_download }}"><i class="fa fa-download"></i> {{ button_download }}</a>
                    <a class="btn btn-danger" id="button-registr_clear" data-loading-text="{{ text_loading }}"><i class="fa fa-eraser"></i> {{ button_clear }}</a>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-2 control-label">{{ entry_log_file }}</label>
                  <div class="col-sm-10">
                    <div class="well well-sm" style="height: 300px; overflow: auto;">
                      <pre id="pre-registr_log" style="font-size:11px; min-height: 280px;">{% for log_registr_line in log_lines %} {{ log_line }}{% endfor %}</pre>
                    </div>
                    <span class="help-block">{{ help_log_file }}</span>
                  </div>
                </div>

              </fieldset>

            </div><!-- </div id="tab-log"> -->
          </div><!-- </div class="tab-content"> -->
        </form>
        <div style="padding: 15px 15px; border:1px solid #ccc; margin-top: 15px; box-shadow:0 0px 5px rgba(0,0,0,0.1);">{{ text_copyright }}</div>
      </div><!-- </div class="panel-body"> -->
    </div><!-- </div class="panel panel-default"> -->
  </div><!-- </div class="container-fluid"> -->
</div><!-- </div id="content"> -->

<script type="text/javascript"><!--
  $('#button-clear').on('click', function() {
    if (confirm('{{ text_confirm }}')){
      $.ajax({
        url: '{{ clear_log }}',
        type: 'post',
        dataType: 'json',
        beforeSend: function() {
          $('#button-clear').button('loading');
        },
        complete: function() {
          $('#button-clear').button('reset');
        },
        success: function(json) {
          $('.alert-success, .alert-danger').remove();
                
          if (json['error']) {
            $('#content > .container-fluid').before('<div class="alert alert-danger" style="display: none;"><i class="fa fa-exclamation-circle"></i> ' + json['error'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            $('.alert-danger').fadeIn('slow');
          }
          
          if (json['success']) {
                    $('#content > .container-fluid').before('<div class="alert alert-success" style="display: none;"><i class="fa fa-check-circle"></i> ' + json['success'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            
            $('#pre-log').empty();
            $('.alert-success').fadeIn('slow');
          }

          $('html, body').animate({ scrollTop: 0 }, 'slow'); 
        },
        error: function(xhr, ajaxOptions, thrownError) {
          alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
      });
    }
  });

  $('#button-registr_clear').on('click', function() {
    if (confirm('{{ text_confirm }}')){
      $.ajax({
        url: '{{ registr_clear_log }}',
        type: 'post',
        dataType: 'json',
        beforeSend: function() {
          $('#button-registr_clear').button('loading');
        },
        complete: function() {
          $('#button-registr_clear').button('reset');
        },
        success: function(json) {
          $('.alert-success, .alert-danger').remove();
                
          if (json['error']) {
            $('#content > .container-fluid').before('<div class="alert alert-danger" style="display: none;"><i class="fa fa-exclamation-circle"></i> ' + json['error'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            $('.alert-danger').fadeIn('slow');
          }
          
          if (json['success']) {
                    $('#content > .container-fluid').before('<div class="alert alert-success" style="display: none;"><i class="fa fa-check-circle"></i> ' + json['success'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            
            $('#pre-registr_log').empty();
            $('.alert-success').fadeIn('slow');
          }

          $('html, body').animate({ scrollTop: 0 }, 'slow'); 
        },
        error: function(xhr, ajaxOptions, thrownError) {
          alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
      });
    }
  });

  $(function() { 
      $('a[href^=\'#tab\']').on('shown.bs.tab', function () {
          localStorage.setItem('antispam_lastTab', $(this).attr('href'));
      });

      var lastTab = localStorage.getItem('antispam_lastTab');
 
      if (lastTab) {
          $('a[href=\'' + lastTab + '\']').tab('show');
      } else {
          $('#tabs_general a:first').tab('show');
      }
  });
//--></script>
{{ footer }}