<script type="text/javascript"><!--
String.prototype.filename=function(extension){
	var s = this.replace(/\\/g, '/');
	return s.substring(s.lastIndexOf('/')+ 1);
}

$(document).ready(function() {
	$('#input-type').on('change', function() {
		$(".input-product_stickers").each(function(i) {
			var filename = $(this).val().filename();
			var folder = 'catalog/product_stickers/' + $('#input-type').val() + '/';
			$(this).val(folder + filename);
			$(this).prev().children().attr('src', '/image/' + folder + filename);
		});
	});
});

var key_price = {{ last_key_price }};

function addStickerPrice() {
    html  = '<tr id="product_stickers-price-row' + key_price + '">';
	html += '<td class="text-left">';
	{% for language in languages %}
	html += '<div class="input-group"><span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span><input type="text" name="module_product_stickers_price[' + key_price + '][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="" /></div>';
    {% endfor %}
	html += '</td>';
	html += '<td class="text-left">';
	html += '<a href="" id="thumb-image-price' + key_price + '" data-toggle="image" class="img-thumbnail"><img class="product_stickers" style="width: 70px;" src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_product_stickers_price[' + key_price + '][image]" value="" class="input-product_stickers" id="input-image-price' + key_price + '" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '<input type="text" name="module_product_stickers_price[' + key_price + '][min]" value="" placeholder="{{ entry_min }}" class="form-control" /><input type="text" name="module_product_stickers_price[' + key_price + '][max]" value="" placeholder="{{ entry_max }}" class="form-control" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '<div class="input-group date"><input type="text" name="module_product_stickers_price[' + key_price + '][date_start]" value="" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div><div class="input-group date"><input type="text" name="module_product_stickers_price[' + key_price + '][date_end]" value="" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" /><span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span></div>';
	html += '</td>';
	html += '<td class="text-left">';
    html += '<select name="module_product_stickers_price[' + key_price + '][status]" class="form-control">';
	html += '<option value="1">{{ text_enabled }}</option>';
	html += '<option value="0" selected="selected">{{ text_disabled }}</option>';
    html += '</select>';
    html += '</td>';
	html += '<td class="text-left">';
	html += '<input type="text" name="module_product_stickers_price[' + key_price + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" id="input-price-sort' + key_price + '" class="form-control" />';
	html += '</td>';
	html += '  <td class="text-right"><button type="button" onclick="$(\'#product_stickers-price-row' + key_price + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';

	$('#product_stickers-price tbody').append(html);
	
	$('.date').datetimepicker({
		pickTime: false
	});
	
	key_price++;
}

