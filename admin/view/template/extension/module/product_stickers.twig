{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
	    <button onclick="$('#content #apply').attr('value', '1'); $('#' + $('#content form').attr('id')).submit();" data-toggle="tooltip" title="{{ button_apply }}" class="btn btn-success"><i class="fa fa-save"></i></button>
        <button type="submit" form="form-product_stickers" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product_stickers" class="form-horizontal">
		  <input type="hidden" name="module_product_stickers_apply" id="apply" value="0" />
		  <ul class="nav nav-tabs">
            <li class="active"><a href="#tab-product" data-toggle="tab"><i class="fa fa-toggle-on"></i> {{ tab_product }}</a></li>
			<li><a href="#tab-product_stickers-new" data-toggle="tab"><i class="fa fa-magic"></i> {{ tab_product_stickers_new }}</a></li>
			<li><a href="#tab-product_stickers-bestseller" data-toggle="tab"><i class="fa fa-bullseye"></i> {{ tab_product_stickers_bestseller }}</a></li>
			<li><a href="#tab-product_stickers-special" data-toggle="tab"><i class="fa fa-gift""></i> {{ tab_product_stickers_special }}</a></li>
			<li><a href="#tab-product_stickers-stock" data-toggle="tab"><i class="fa fa-eye-slash"></i> {{ tab_product_stickers_stock }}</a></li>
			<li><a href="#tab-product_stickers-price" data-toggle="tab"><i class="fa fa-usd"></i> {{ tab_product_stickers_price }}</a></li>
			<li><a href="#tab-product_stickers-custom" data-toggle="tab"><i class="fa fa-user"></i> {{ tab_product_stickers_custom }}</a></li>
            <li><a href="#tab-info" data-toggle="tab"><i class="fa fa-info"></i> {{ tab_info }}</a></li>
          </ul>
		  <div class="tab-content">
			<div class="tab-pane active" id="tab-product">
			  <fieldset>
			  <legend>{{ text_product }}</legend>
				<div class="form-group">
                  <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-9">
                    <select name="module_product_stickers_status" id="input-status" class="form-control">
                      {% if module_product_stickers_status %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                  </div>
                </div>
			    <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-position">{{ entry_position }}  </label>
                  <div class="col-sm-9">
                    <select name="module_product_stickers_position" class="form-control" id="input-position">
				      {% if module_product_stickers_position == 'right' %}
				      <option value="right" selected="selected">{{ text_right }}</option>
				      <option value="left">{{ text_left }}</option>
				      {% else %}
				      <option value="right">{{ text_right }}</option>
				      <option value="left" selected="selected">{{ text_left }}</option>
				      {% endif %}
				    </select>
                  </div>
                </div>
			    <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-type">{{ entry_type }}</label>
                  <div class="col-sm-9">
                    <select name="module_product_stickers_type" class="form-control" id="input-type">
			          <option value="star"{% if module_product_stickers_type == 'star' %} selected="selected"{% endif %}>{{ text_star }}</option>
					  <option value="triangle"{% if module_product_stickers_type == 'triangle' %} selected="selected"{% endif %}>{{ text_triangle }}</option>
					  <option value="circle"{% if module_product_stickers_type == 'circle' %} selected="selected"{% endif %}>{{ text_circle }}</option>
			          <option value="double-ribbon"{% if module_product_stickers_type == 'double-ribbon' %} selected="selected"{% endif %}>{{ text_double_ribbon }}</option>
					  <option value="ribbon"{% if module_product_stickers_type == 'ribbon' %} selected="selected"{% endif %}>{{ text_ribbon }}</option>
					  <option value="diagonal-stripe"{% if module_product_stickers_type == 'diagonal-stripe' %} selected="selected"{% endif %}>{{ text_diagonal_stripe }}</option>
					  <option value="diagonal-ribbon"{% if module_product_stickers_type == 'diagonal-ribbon' %} selected="selected"{% endif %}>{{ text_diagonal_ribbon }}</option>
				    </select>
                 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-new">
			<fieldset>
				<legend>{{ text_product_stickers_new }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-date-new">{{ entry_date_new }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_new[date_new]" id="input-date-new" class="form-control">
					  {% if module_product_stickers_new.date_new %}
					  <option value="1" selected="selected">{{ text_date_added }}</option>
					  <option value="0">{{ text_date_available }}</option>
					  {% else %}
					  <option value="1">{{ text_date_added }}</option>
					  <option value="0" selected="selected">{{ text_date_available }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-day">{{ entry_day }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_new[day]" value="{{ module_product_stickers_new.day }}" placeholder="{{ entry_day }}" id="input-new-day" class="form-control" />
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_new[status]" id="input-new-status" class="form-control">
					  {% if module_product_stickers_new.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-new-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_new[sort_order]" value="{{ module_product_stickers_new.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-new-sort-order" class="form-control" />
				  </div>
                 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-bestseller">
			<fieldset>
				<legend>{{ text_product_stickers_bestseller }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-sale">{{ entry_sale }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_bestseller[sale]" value="{{ module_product_stickers_bestseller.sale }}" placeholder="{{ entry_sale }}" id="input-bestseller-sale" class="form-control" />
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_bestseller[status]" id="input-bestseller-status" class="form-control">
					  {% if module_product_stickers_bestseller.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-bestseller-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_bestseller[sort_order]" value="{{ module_product_stickers_bestseller.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-bestseller-sort-order" class="form-control" />
				  </div>
                 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-special">
			<fieldset>
				<legend>{{ text_product_stickers_special }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-label">{{ entry_label }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_special[label]" class="form-control" id="input-special-label">
					  {% if module_product_stickers_special.label == 2 %}
					  <option value="2" selected="selected">{{ text_label_text_percent }}</option>
					  <option value="1">{{ text_label_percent }}</option>
					  <option value="0">{{ text_label_text }}</option>
					  {% elseif module_product_stickers_product_stickers_special.label == 1 %}
					  <option value="2">{{ text_label_text_percent }}</option>
					  <option value="1" selected="selected">{{ text_label_percent }}</option>
					  <option value="0">{{ text_label_text }}</option>
					  {% else %}
					  <option value="2">{{ text_label_text_percent }}</option>
					  <option value="1">{{ text_label_percent }}</option>
					  <option value="0" selected="selected">{{ text_label_text }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_special[status]" id="input-special-status" class="form-control">
					  {% if module_product_stickers_special.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-special-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_special[sort_order]" value="{{ module_product_stickers_special.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-special-sort-order" class="form-control" />
                  </div>
				 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-stock">
			<fieldset>
				<legend>{{ text_product_stickers_stock }}</legend>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-stock-status">{{ entry_status }}</label>
				  <div class="col-sm-9">
					<select name="module_product_stickers_stock[status]" id="input-stock-status" class="form-control">
					  {% if module_product_stickers_stock.status %}
					  <option value="1" selected="selected">{{ text_enabled }}</option>
					  <option value="0">{{ text_disabled }}</option>
					  {% else %}
					  <option value="1">{{ text_enabled }}</option>
					  <option value="0" selected="selected">{{ text_disabled }}</option>
					  {% endif %}
					</select>
				  </div>
				</div>
				<div class="form-group">
				  <label class="col-sm-3 control-label" for="input-stock-sort-order">{{ entry_sort_order }}</label>
				  <div class="col-sm-9">
					<input type="text" name="module_product_stickers_stock[sort_order]" value="{{ module_product_stickers_stock.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-stock-sort-order" class="form-control" />
                  </div>
				 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-price">
			<fieldset>
				<legend>{{ text_product_stickers_price }}</legend>
				<div class="table-responsive">
				  <table id="product_stickers-price" class="table table-striped table-bordered table-hover">
					<thead>
					  <tr>
						<td class="text-left required">{{ entry_name }}</td>
						<td class="text-left">{{ entry_image }}</td>
						<td class="text-left">{{ entry_price }}</td>
						<td class="text-left">{{ entry_date }}</td>
						<td class="text-left">{{ entry_status }}</td>
						<td class="text-left">{{ entry_sort_order }}</td>
						<td></td>
					  </tr>
					</thead>
					<tbody>
					  {% set last_key_price = 0 %}
					  {% for key, product_stickers in module_product_stickers_price %}
					  <tr id="product_stickers-price-row{{ key }}">
						<td class="text-left">
						  {% for language in languages %}
						  <div class="input-group">
							<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
							<input type="text" name="module_product_stickers_price[{{ key }}][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="{{ product_stickers[language.language_id]['name'] }}" />
						  </div>
						  {% if error_product_stickers_price_name[key][language.language_id] is defined %}
						  <div class="text-danger">{{ error_product_stickers_price_name[key][language.language_id] }}</div>
						  {% endif %}
						  {% endfor %}
						</td>
						<td class="text-left">
						  <a href="" id="thumb-image-price{{ key }}" data-toggle="image" class="img-thumbnail"><img class="product_stickers" style="width: 70px;" src="{% if product_stickers.image %}/image/{{ product_stickers.image}}{% else %}{{ placeholder }}{% endif %}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_product_stickers_price[{{ key }}][image]" value="{{ product_stickers.image }}" class="input-product_stickers" id="input-image-price{{ key }}" />
						</td>
						<td class="text-left">
						  <input type="text" name="module_product_stickers_price[{{ key }}][min]" value="{{ product_stickers.min }}" placeholder="{{ entry_min }}" class="form-control" />
						  <input type="text" name="module_product_stickers_price[{{ key }}][max]" value="{{ product_stickers.max }}" placeholder="{{ entry_max }}" class="form-control" />
						</td>
						<td class="text-left">
						  <div class="input-group date">
						    <input type="text" name="module_product_stickers_price[{{ key }}][date_start]" value="{{ product_stickers.date_start }}" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						  <div class="input-group date">
						    <input type="text" name="module_product_stickers_price[{{ key }}][date_end]" value="{{ product_stickers.date_end }}" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						</td>
						<td class="text-left">
						  <select name="module_product_stickers_price[{{ key }}][status]" class="form-control">
							{% if product_stickers.status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</td>
						<td class="text-left">
						  <input type="text" name="module_product_stickers_price[{{ key }}][sort_order]" value="{{ product_stickers.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control" />
						</td>
						<td class="text-right"><button type="button" onclick="$('#product_stickers-price-row{{ key }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
					  </tr>
					  {% set last_key_price = key + 1 %}
					  {% endfor %}
					</tbody>
					<tfoot>
					  <tr>
						<td colspan="6"></td>
						<td class="text-right"><button type="button" onclick="addStickerPrice();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
					  </tr>
					</tfoot>
				  </table>
				 </div>
			   </fieldset>
			  </div>
			<div class="tab-pane" id="tab-product_stickers-custom">
			<fieldset>
				<legend>{{ text_product_stickers_custom }}</legend>
				<div class="table-responsive">
				  <table id="product_stickers-custom" class="table table-striped table-bordered table-hover">
					<thead>
					  <tr>
						<td class="text-left required">{{ entry_name }}</td>
						<td class="text-left">{{ entry_image }}</td>
						<td class="text-left">{{ entry_date }}</td>
						<td class="text-left">{{ entry_status }}</td>
						<td class="text-left">{{ entry_sort_order }}</td>
						<td></td>
					  </tr>
					</thead>
					<tbody>
					  {% set last_key_custom = 0 %}
					  {% for key, product_stickers in module_product_stickers_custom %}
					  <tr id="product_stickers-custom-row{{ key }}">
						<td class="text-left">
						  {% for language in languages %}
						  <div class="input-group">
							<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
							<input type="text" name="module_product_stickers_custom[{{ key }}][{{ language.language_id }}][name]" placeholder="{{ entry_name }}" class="form-control" value="{{ product_stickers[language.language_id]['name'] }}" />
						  </div>
						  {% if error_product_stickers_custom_name[key][language.language_id] is defined %}
						  <div class="text-danger">{{ error_product_stickers_custom_name[key][language.language_id] }}</div>
						  {% endif %}
						  {% endfor %}
						</td>
						<td class="text-left">
						  <a href="" id="thumb-image-custom{{ key }}" data-toggle="image" class="img-thumbnail"><img class="product_stickers" style="width: 70px;" src="{% if product_stickers.image %}/image/{{ product_stickers.image }}{% else %}{{ placeholder }}{% endif %}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="module_product_stickers_custom[{{ key }}][image]" value="{{ product_stickers.image }}" class="input-product_stickers" id="input-image-custom{{ key }}" />
						</td>
						<td class="text-left">
						  <div class="input-group date">
						    <input type="text" name="module_product_stickers_custom[{{ key }}][date_start]" value="{{ product_stickers.date_start }}" placeholder="{{ entry_date_start }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						  <div class="input-group date">
						    <input type="text" name="module_product_stickers_custom[{{ key }}][date_end]" value="{{ product_stickers.date_end }}" placeholder="{{ entry_date_end }}" class="form-control" data-date-format="YYYY-MM-DD" />
							<span class="input-group-btn"><button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button></span>
						  </div>
						</td>
						<td class="text-left">
						  <select name="module_product_stickers_custom[{{ key }}][status]" class="form-control">
							{% if product_stickers.status %}
							<option value="1" selected="selected">{{ text_enabled }}</option>
							<option value="0">{{ text_disabled }}</option>
							{% else %}
							<option value="1">{{ text_enabled }}</option>
							<option value="0" selected="selected">{{ text_disabled }}</option>
							{% endif %}
						  </select>
						</td>
						<td class="text-left">
						  <input type="text" name="module_product_stickers_custom[{{ key }}][sort_order]" value="{{ product_stickers.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control" />
						</td>
						<td class="text-right"><button type="button" onclick="$('#product_stickers-custom-row{{ key }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
					  </tr>
					  {% set last_key_custom = key + 1 %}
					  {% endfor %}
					</tbody>
					<tfoot>
					  <tr>
						<td colspan="5"></td>
						<td class="text-right"><button type="button" onclick="addStickerCustom();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
					  </tr>
					</tfoot>
				  </table>
				</div>
			  </fieldset>
			</div>
			<div class="tab-pane" id="tab-info">
             <div class="row">
              <div class="col-md-6 col-xs-12">
                <h4 class="text-success text-center">Спасибо за покупку модуля  <i class="fa fa-shopping-cart"></i></h4>
                  <div class="panel-body text-center">
                    <h4><i class="fa fa-puzzle-piece"></i> {{ heading_title }}</h4>
                    <h5><i class="fa fa-toggle-on"></i> Установленная версия: {{ OC3X_version }} </h5>
                    <h5><i class="fa fa-lock"></i> Последняя версия: {{ OC3X_version }}</a></span></h5>
                    <br>
                    <h5 class="hidden-sm"><a style="background: url('') 0px 0px no-repeat; padding-left: 20px; " title="Перейти на oc3x.ru"  href="https://oc3x.ru/moduli-opencart" target="_blank"><i class="fa fa-opencart"  style="color: #1e91cf; aria-hidden="true"></i> Еще больше модулей OpenCart 3 на нашем сайте</a></h5><br>
                  </div>
             </div>
             <div class="col-md-6 col-xs-12">
                <h4><i class="fa fa-info-circle"></i> Пожалуйста, сообщите нам, о проблемах, и оставьте отзыв!</h4>
				 <br>
                  <div id="contact-infor" class="text-center">
