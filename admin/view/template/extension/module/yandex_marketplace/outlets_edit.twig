$('input[name=\'address_city\']').autocomplete({
	  'source': function(request, response) {
		  $.ajax({
			  url: 'index.php?route=extension/module/yandex_marketplace/outlets/getAjaxRegion&user_token={{ user_token }}',
			  data: {
                "outlet_region": $('input[name=\'address_city\']').val(),
                },
              type: 'POST',
			  dataType: 'json',
			  success: function(json) {
			  console.log();
			  response($.map(json, function(item) {
					  return {
						  label: item['html'],
						  value: item['region_id']
					  }
				  }));
			  }
		  });
	  },
	  'select': function(item) {
		  $('#input-city').val(item['label']);
          $('#input-region-id').val(item['value']);
          $('.region-info').text(item['label']);
	  }
  });
</script>

<script type="text/javascript">
    $('.phone-field').inputmask("+7(999)999-99-99");
    jQuery.validator.addMethod("checkMaskPhone", function(value, element) {
        return /\+\d{1}\(\d{3}\)\d{3}-\d{4}/g.test(value); 
    });
    
    $('.orderBefore-field').inputmask("99");
    jQuery.validator.addMethod("checkMaskOrderBefore", function(value, element) {
        return /\+\d{1}\(\d{3}\)\d{3}-\d{4}/g.test(value); 
    });
    
    $('#input-storagePeriod').inputmask("99");
    jQuery.validator.addMethod("checkMaskStoragePeriod", function(value, element) {
        return /\+\d{1}\(\d{3}\)\d{3}-\d{4}/g.test(value); 
    });
    
    var form = $('.form-horizontal');
    form.validate();
</script>

{{ footer }}
