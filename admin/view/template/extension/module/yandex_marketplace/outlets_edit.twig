{{ header }}{{ column_left }}

<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<button type="submit" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save" ></i></button>
        		<a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
			</div>
			<h1>{{ heading_title_market }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
				<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	
	<div class="container-fluid">
		{% if error_warning %}
		<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
			<button type="button" class="close" data-dismiss="alert">&times;</button>
		</div>
		{% endif %}
		{% if success %}
		<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
			<button type="button" class="close" data-dismiss="alert">&times;</button>
		</div>
		{% endif %}
		<div class="container-fluid">
			<div class="row">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-sale-point" class="form-horizontal">
                    <div class="col-md-12 sale-point-add">
                        <div class="form-group required">
                            <label class="col-sm-2 control-label" for="input-name">{{ text_outlet_name }}</label>
                            <div class="col-sm-10">
                            <input type="text" name="name" value="{{ outlet.name }}" placeholder="{{ name }}" id="input-name" class="form-control"/>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-point-type">{{ text_outlet_type }}</label>
                            <div class="col-sm-5">
                                <select name="type" id="input-type" class="form-control">
                                    <option value="DEPOT" selected="selected">Пункт выдачи заказов</option>
                                    <option value="MIXED">Смешанный тип точки продаж (торговый зал и пункт выдачи заказов)</option>
                                    <option value="RETAIL">Розничная точка продаж (торговый зал)</option>
                                </select>
                            </div> 
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-id"><span data-toggle="tooltip" title="{{ help_outlet_id }}">{{ text_outlet_id }}</span></label>
                            <div class="col-sm-10">
                            <input type="text" name="id" value="{{ outlet.id }}" placeholder="{{ text_outlet_id }}" id="input-id" class="form-control"/>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-isMain"><span data-toggle="tooltip" title="{{ help_outlet_isMain }}">{{ text_outlet_is_main }}</span></label>
                            <div class="col-sm-10">
                            <input type="checkbox" name="isMain" value="{{ outlet.isMain }}"  id="input-isMain" class="form-control" {% if outlet.isMain %} checked {% endif %}/>
                            </div>
                        </div>
      
                        <div class="form-group">
                            <label class="col-sm-2 control-label">{{ text_outlet_address }}</label>
                            <div class="col-sm-6">
                                <input type="text" name="address_city" value="{{ outlet.address.city }}" placeholder="Город" id="input-city" class="form-control"/>
                                <input type="text" name="address_street" value="{{ outlet.address.street }}" placeholder="Улица" id="input-street" class="form-control"/>
                                <input type="text" name="address_number" value="{{ outlet.address.number }}" placeholder="Дом" id="input-number" class="form-control"/>
                                <input type="hidden" name="region_id" value="{{ outlet.address.regionId }}" placeholder="{{ text_outlet_id }}" id="input-region-id" class="form-control"/>
                                <span class="region-info"></span>
                            </div>
                        </div>
                        
                        <div class="form-group">
                           <label class="col-sm-2 control-label" for="input-point-worktime">{{ text_outlet_worktime }}</label>
                            <div class="col-sm-10" id="worktime-row">
                              {% set worktime_row = 0 %}
                              {% for key, items in outlet.workingSchedule.scheduleItems %}
                                <div class="row" id="worktime-row-{{worktime_row}}">
                                    <div class="col-sm-3">
                                        <select name="sale_worktime[{{key}}][startDay]" id="input-start-workday{{key}}" class="form-control">
                                            <option value="MONDAY" selected="selected">Понедельник</option>
                                            <option value="TUESDAY">Вторник</option>
                                            <option value="WEDNESDAY">Среда</option>
                                            <option value="THURSDAY">Четверг</option>
                                            <option value="FRIDAY">Пятница</option>
                                            <option value="SATURDAY">Суббота</option>
                                            <option value="SUNDAY">Воскресенье</option>
                                        </select>
                                    </div>
                                    <div class="col-sm-3">
                                        <select name="sale_worktime[{{key}}][endDay]" id="input-end-workday{{key}}" class="form-control">
                                            <option value="MONDAY">Понедельник</option>
                                            <option value="TUESDAY">Вторник</option>
                                            <option value="WEDNESDAY">Среда</option>
                                            <option value="THURSDAY">Четверг</option>
                                            <option value="FRIDAY" selected="selected">Пятница</option>
                                            <option value="SATURDAY">Суббота</option>
                                            <option value="SUNDAY">Воскресенье</option>
                                        </select>
                                    </div>
                                
                                    <div class="col-sm-2">
                                        <input type="time" name="sale_worktime[{{key}}][startTime]" value="{{ items.startTime }}" placeholder="09:00" id="input-start-worktime{{key}}" class="form-control"/>
                                    </div> 
                                    <div class="col-sm-2">
                                        <input type="time" name="sale_worktime[{{key}}][endTime]" value="{{ items.endTime }}" placeholder="17:00" id="input-end-worktime{{key}}" class="form-control"/>
                                    </div>
                                    {% if worktime_row != 0 %}
                                        <button type="button" onclick="$('#worktime-row-{{worktime_row}}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button>
                                    {% else %}
                                        <button type="button" onclick="addWorktime();" data-toggle="tooltip" title="{{ button_attribute_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button>
                                    {% endif %}
                                </div>
                                {% set worktime_row = worktime_row + 1 %}
                                {% endfor %}
                                {% if error_sale_worktime %}
                                    <div class="text-danger">{{ error_sale_worktime }}</div>
                                {% endif %}
                           </div> 
                        </div>
                        
                        <div class="form-group deliveryRules">
                            <label class="col-sm-2 control-label" ><span data-toggle="tooltip" title="{{ help_delivery_rules }}">{{ text_outlet_delivery_rules }}</span></label>
                            <div class="col-sm-10">
                                {% for rule in outlet.deliveryRules %}
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Стоимость</label>
                                        <div class="col-sm-5">
                                            <input type="text" name="cost" value="{{ rule.cost }}" placeholder="Стоимость" class="form-control"/>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Минимальное количество дней</label>
                                        <div class="col-sm-5">
                                            <input type="text" name="minDeliveryDays" value="{{ rule.minDeliveryDays }}" placeholder="Минимальное количество дней" class="form-control"/>
                                            {% if error_min_max_delivery_days %}
                                            <div class="text-danger">{{ error_min_max_delivery_days }}</div>
                                            {% endif %}
                                            {% if error_other_region_delivery_1 %}
                                                <div class="text-danger">{{ error_other_region_delivery_1 }}</div>
                                            {% endif %}
                                            {% if error_other_region_delivery_2 %}
                                                <div class="text-danger">{{ error_other_region_delivery_2 }}</div>
                                            {% endif %}
                                            {% if error_own_region_delivery %}
                                                <div class="text-danger">{{ error_own_region_delivery }}</div>
                                            {% endif %}
                                        </div>
                                    </div>    
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">Максимальное количество дней</label>
                                        <div class="col-sm-5">
                                            <input type="text" name="maxDeliveryDays" value="{{ rule.maxDeliveryDays }}" placeholder="Максимальное количество дней" class="form-control"/>
                                            {% if error_min_max_delivery_days %}
                                            <div class="text-danger">{{ error_min_max_delivery_days }}</div>
                                            {% endif %}
                                            {% if error_other_region_delivery_1 %}
                                                <div class="text-danger">{{ error_other_region_delivery_1 }}</div>
                                            {% endif %}
                                            {% if error_other_region_delivery_2 %}
                                                <div class="text-danger">{{ error_other_region_delivery_2 }}</div>
                                            {% endif %}
                                            {% if error_own_region_delivery %}
                                                <div class="text-danger">{{ error_own_region_delivery }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label"><span data-toggle="tooltip" title="{{ help_outlet_orderBefore }}">Заказ до</span></label>
                                        <div class="col-sm-5">
                                            <input type="text" name="orderBefore" value="{{ rule.orderBefore }}" placeholder="Заказ до (час)" class="form-control orderBefore-field"/>
                                        </div>
                                    </div>                                      
                                {% endfor %}
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-phones"><span data-toggle="tooltip" title="{{ help_outlet_phone }}">{{ text_outlet_phone }}</span></label>
                            <div class="col-sm-10">
                                <div class="phone-field-block">
                                {% for phone in outlet.phones %}
                                    <input type="text" name="phones" value="{{ phone }}" placeholder="{{ text_outlet_phone }}" class="form-control phone-field"/>
                                {% endfor %}
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-storagePeriod"><span data-toggle="tooltip" title="{{ help_outlet_storagePeriod }}">{{ text_outlet_storagePeriod }}</span></label>
                            <div class="col-sm-10">
                            <input type="text" name="storagePeriod" value="{{ outlet.storagePeriod }}" placeholder="{{ text_outlet_id }}" id="input-storagePeriod" class="form-control"/>
                            {% if error_storagePeriod %}
                                <div class="text-danger">{{ error_storagePeriod }}</div>
                            {% endif %}
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-visibility">{{ text_outlet_condition }}</label>
                            <div class="col-sm-10">
                             <select name="visibility" id="input-visibility" class="form-control">
                                <option value="VISIBLE" selected="selected">Включено</option>
                                <option value="HIDDEN">Отключено</option>
                            </select>
                            </div>
                        </div>
                  {#      
                        <div class="form-group">
                            <label class="col-sm-2 control-label" for="input-status">{{ text_outlet_condition }}</label>
                            <div class="col-sm-10">
                            <select name="status" id="input-status" class="form-control">
                                <option value="HIDDEN" selected="selected">Включено</option>
                                <option value="VISIBLE">Отключено</option>
                            </select>
                            </div>
                        </div>
                   #}     
                    </div>
                </form>
			</div>
		</div>
	</div>

</div>

<div id="modal" class="modal" style="display: none;"></div>
<script src="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.js" type="text/javascript"></script>
<link href="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.css" type="text/css" rel="stylesheet" media="screen" />

<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.16.0/jquery.validate.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.5/jquery.inputmask.min.js"></script>

<script>
    $(document).ready(function() {
    if($("#input-type").val() == "RETAIL"){
            $(".deliveryRules").hide();
        }
    });

    $( "#input-type" ).change(function() {
    if($("#input-type").val() == "RETAIL"){
        $(".deliveryRules").hide();
    }else{
        $(".deliveryRules").show();
    }
});
</script>

<script>
    $("#input-type").val("{{ outlet.type }}"); 
    
    $("#input-visibility").val("{{ outlet.visibility }}");
    
    {% for key, items in outlet.workingSchedule.scheduleItems %}
        $("#input-start-workday{{key}}").val("{{ items.startDay }}");
        $("#input-end-workday{{key}}").val("{{ items.endDay }}");
        
        var worktime_row = {{ key }} + 1;
    {% endfor %}

    function addWorktime(){
        html = '<div class="row" id="worktime-row-' + worktime_row +'">';
        html+= '    <div class="col-sm-3">';
        html+= '          <select name="sale_worktime[' + worktime_row + '][startDay]" id="input-start-workday" class="form-control">'
        html+= '                <option value="MONDAY" selected="selected">Понедельник</option><option value="TUESDAY">Вторник</option><option value="WEDNESDAY">Среда</option><option value="THURSDAY">Четверг</option><option value="FRIDAY">Пятница</option><option value="SATURDAY">Суббота</option><option value="SUNDAY">Воскресенье</option></select></div>';
        html+= '    <div class="col-sm-3">';
        html+= '          <select name="sale_worktime[' + worktime_row + '][endDay]" id="input-end-workday" class="form-control">';
        html+= '                <option value="MONDAY">Понедельник</option><option value="TUESDAY">Вторник</option><option value="WEDNESDAY">Среда</option><option value="THURSDAY">Четверг</option><option value="FRIDAY" selected="selected">Пятница</option><option value="SATURDAY">Суббота</option><option value="SUNDAY">Воскресенье</option></select></div>'; 
        html+= '<div class="col-sm-2">';
        html+= '    <input type="time" name="sale_worktime[' + worktime_row + '][startTime]" placeholder="09:00" id="input-start-worktime" class="form-control"/></div>'; 
        html+= ' <div class="col-sm-2">';
        html+= ' <input type="time" name="sale_worktime[' + worktime_row + '][endTime]" placeholder="17:00" id="input-end-worktime" class="form-control"/></div><button type="button" onclick="$(\'#worktime-row-' + worktime_row +'\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></div>';

        $('#worktime-row').append(html);

        worktime_row++;
    }
</script>

