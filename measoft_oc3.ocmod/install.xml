        <operation error="skip">
            <search>
                <![CDATA[<div class="buttons">]]>
            </search>
            <add position='before'>
                <![CDATA[
                <script>
                    document.querySelectorAll('input[name="shipping_method"]').forEach(e=>{
                    e.onchange = ev => {
                        let def_btn = document.querySelector('#button-shipping-method');
                        let code_e = document.querySelector('.pvzcode');
                        if (ev.target.value === "measoftcouriershipping.standard" ) {
                        def_btn.setAttribute('disabled', !code_e.value);
                        } else {
                        def_btn.removeAttribute('disabled');
                        }
                    }
                    })
                </script>
                ]]>
            </add>
        </operation>  		
