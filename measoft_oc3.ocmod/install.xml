        <operation error="skip">
            <search><![CDATA[
				public function shipping() {				
			]]></search>
            <add position='before'>
                <![CDATA[
				public function saveSession() 
				{
					if (isset($this->request->get['order_id']) && $this->request->get['order_id']) {
						$order_id = $this->request->get['order_id'];
						$post = json_decode(html_entity_decode($this->request->post['data'],ENT_QUOTES), true);
						$this->load->model('sale/order');
						if (isset($post['pvz_id'])) {
							$data = array(
								'pvz_id'	=> $post['pvz_id'],
								'order_id'	=> $this->request->get['order_id'],
							);
							$this->model_sale_order->updateOrderPvz($data);
							
						}
						if (isset($post['pvz_name'])) {
							$data = array(
								'pvz_name'	=> $post['pvz_name'],
								'order_id'	=> $this->request->get['order_id'],
							);
							$this->model_sale_order->updateOrderPvz($data);
						}
					}
					$this->response->addHeader('Content-Type: application/json; charset=utf-8');
					$this->response->setOutput(json_encode([]));
				}
                ]]>
            </add>
        </operation>					
	</file>

