				<![CDATA[
					public function updateOrderPvz($data) {
						if (isset($data['pvz_id'])) {
							$this->db->query("UPDATE `" . DB_PREFIX . "order` SET  pvz_id = '" . $this->db->escape($data['pvz_id']) . "' WHERE order_id = '".$data['order_id']."'");
						}
						if (isset($data['pvz_name'])) {
							$this->db->query("UPDATE `" . DB_PREFIX . "order` SET  pvz_name = '" . $this->db->escape($data['pvz_name']) . "' WHERE order_id = '".$data['order_id']."'");
						}
					}
				]]>
